# ─── Prowlarr ──────────────────────────────────────────────────────────────────
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# ─── qBittorrent ───────────────────────────────────────────────────────────────
QBIT_URL=http://qbittorrent:8080
QBIT_USERNAME=admin
QBIT_PASSWORD=
# Optional: qBittorrent category to assign to bookarr torrents.
# QBIT_CATEGORY=bookarr

# ─── Library ───────────────────────────────────────────────────────────────────
# Root of your audiobook library (also shared with Audiobookshelf).
LIBRARY_DIR=/audiobooks
# Where completed downloads appear locally. Defaults to qBittorrent's configured
# save path (read via API at startup). Set explicitly when using Syncthing to
# deliver files from a remote seedbox.
# WATCH_DIR=/syncthing/audiobooks
# How long to wait for a file to appear in WATCH_DIR before giving up (default 24h).
# WATCH_TIMEOUT=24h

# ─── Metadata ──────────────────────────────────────────────────────────────────
# Optional: Audnexus base URL. Leave blank to disable Audnexus lookups.
# AUDNEXUS_URL=https://api.audnexus.com

# ─── Audiobookshelf (unused — ABS auto-watches the library dir) ───────────────
# ABS_URL=http://audiobookshelf:13378
# ABS_API_KEY=
# ABS_LIBRARY_ID=

# ─── Discord ───────────────────────────────────────────────────────────────────
# Optional: leave blank to disable Discord notifications.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Required. Generate with: openssl rand -hex 32
JWT_SECRET=
# Optional (default 24h).
# JWT_EXPIRY=24h

# ─── First admin account ───────────────────────────────────────────────────────
# Only used on the very first startup when the users table is empty.
# Change the password after first login or set a strong one here.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ─── Wizarr integration ────────────────────────────────────────────────────────
# Service token for POST /api/users. Leave blank to disable the endpoint.
# SERVICE_TOKEN=

# ─── Database ──────────────────────────────────────────────────────────────────
# Path inside the container (backed by the bookarr_data volume).
# DB_PATH=/data/bookarr.db

# ─── Server ────────────────────────────────────────────────────────────────────
# PORT=8008
# Path to the compiled frontend. In Docker this is /app/static (the default).
# For local dev outside Docker, point this at frontend/dist after running npm run build.
# STATIC_DIR=/app/static
